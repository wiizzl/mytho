{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "jsx-a11y", "import", "promise", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "style": "off",
    "pedantic": "off",
    "nursery": "off",
    "restriction": "off"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/no-array-index-key": "off",
    "import/no-unassigned-import": "off"
  },
  "settings": {
    "react": {
      "version": "19.2.4"
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": ["apps/frontend/src/routeTree.gen.ts"]
}
