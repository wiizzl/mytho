{
  "name": "@mytho/backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile build/server src/index.ts",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@mytho/shared": "workspace:*",
    "elysia": "^1.4.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
